# Copiá este archivo como .env para desarrollo local (NUNCA lo subas al repo)

# Conexión a la base de datos Supabase/Postgres
DB_HOST=44.238.118.41
DB_USER=postgres.uhxhqbqmlurlxtydvqad
SUPABASE_DB_PASSWORD=tu-password-de-supabase
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Secreto para firmar los JWT de autenticación propia
JWT_SECRET=genera-un-secreto-aleatorio-largo

# Credenciales públicas de Supabase (Project Settings -> API)
# Necesarias para validar el access_token de Supabase Auth en el login con Google
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Puerto local (Railway lo asigna solo en producción vía PORT)
PORT=3001
NODE_ENV=development
